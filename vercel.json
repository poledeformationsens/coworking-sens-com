{
  "rewrites": [
    {
      "source": "/facture/:sid.pdf",
      "destination": "https://pole-iad-sens.fr/api/coworking/invoice/:sid.pdf"
    },
    {
      "source": "/api/coworking/:path*",
      "destination": "https://pole-iad-sens.fr/api/coworking/:path*"
    },
    {
      "source": "/mon-espace/reset-password",
      "destination": "/mon-espace.html"
    },
    {
      "source": "/mon-espace/:token",
      "destination": "/mon-espace.html?token=:token"
    },
    {
      "source": "/mon-espace",
      "destination": "/mon-espace.html"
    }
  ]
}
